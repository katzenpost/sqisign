# Rust build artifacts
/target
**/*.rs.bk
Cargo.lock.orig

# Instrumented C reference build tree (out-of-tree, never committed)
/build-instrumented/

# Raw binary dump logs emitted by the instrumented reference. These are an
# intermediate artifact: vector-gen consumes them to produce the canonical
# JSON under vectors/, which IS committed. The raw logs are not.
/dumps/
*.vecdump

# Optional CBOR cache, regenerated from the canonical JSON on demand.
/vectors-cache/

# Criterion output
/target/criterion/

# cargo-fuzz: commit the harness (Cargo.toml, fuzz_targets/), never the
# build tree, generated corpus, or crash artifacts.
**/fuzz/target/
**/fuzz/corpus/
**/fuzz/artifacts/
**/fuzz/Cargo.lock

# Python binding build artefacts
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Go binding test artefacts (cgo build cache lives in $GOCACHE outside the repo)
